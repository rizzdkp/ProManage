APP_ENV=production
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=promanage

JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRE_HOURS=24

CORS_ORIGINS=http://YOUR_VPS_IP
CORS_ALLOW_CREDENTIALS=false

ALLOW_PUBLIC_REGISTER=false
SINGLE_ADMIN_ONLY=true
BOOTSTRAP_ADMIN_NAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@your-server.local
BOOTSTRAP_ADMIN_PHONE=628000000001
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=webhook
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_WEBHOOK_AUTH_HEADER=Authorization
WHATSAPP_WAHA_BASE_URL=http://127.0.0.1:3000
WHATSAPP_WAHA_API_KEY=
WHATSAPP_WAHA_SESSION=default
WHATSAPP_TIMEOUT_SECONDS=10
